    "user_role_changed_description" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تم تغيير دور حسابك. يرجى تسجيل الدخول مرة أخرى لمتابعة استخدام التطبيق بصلاحياتك المحدثة."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your account role has been changed. Please log in again to continue using the app with your updated access permissions."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El rol de tu cuenta ha cambiado. Por favor, inicia sesión nuevamente para continuar usando la aplicación con tus permisos actualizados."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "आपकी खाता भूमिका बदल दी गई है। अपडेट की गई एक्सेस अनुमतियों के साथ ऐप का उपयोग जारी रखने के लिए कृपया फिर से लॉग इन करें।"
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "آپ کے اکاؤنٹ کا کردار تبدیل کر دیا گیا ہے۔ اپ ڈیٹ شدہ رسائی اجازتوں کے ساتھ ایپ استعمال جاری رکھنے کے لیے براہ کرم دوبارہ لاگ ان کریں۔"
          }
        }
      }
    },
