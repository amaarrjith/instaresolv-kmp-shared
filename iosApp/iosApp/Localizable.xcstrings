    "share_message" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تقرير أثناء التنقل\n\nتمت دعوتك إلى مجموعة في تطبيق Report On The Go لنظام iOS\nاسم المجموعة: %@\nرمز المجموعة: %@\nأدخل الرمز أعلاه للانضمام\n\nقم بتثبيت ALNASR الآن"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AlNasr\n\nYou are invited to a group in AlNasr iOS\nGroup Name: %@\nGroup Code: %@\nEnter the above code to join\n\nInstall ALNASR now."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "alnasr\n\nEstás invitado a un grupo en AlNasr iOS\nNombre del grupo: %@\nCódigo de grupo: %@\nIngrese el código anterior para unirse\n\nInstale ALNASR ahora."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "अलनस्र\n\nआपको AlNasr iOS में एक समूह में आमंत्रित किया गया है\nसमूह का नाम: %@\nसमूह कोड: %@\nशामिल होने के लिए उपरोक्त कोड दर्ज करें\n\nअभी ALNASR इंस्टॉल करें."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "النصر\n\nآپ کو النصر iOS میں ایک گروپ میں مدعو کیا گیا ہے۔\nگروپ کا نام: %@\nگروپ کوڈ: %@\nشامل ہونے کے لیے اوپر کا کوڈ درج کریں۔\n\nALNASR ابھی انسٹال کریں۔"
          }
        }
      }
    },
