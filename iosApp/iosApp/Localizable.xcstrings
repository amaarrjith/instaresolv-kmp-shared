    "incident_draft_delete_message" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هل أنت متأكد أنك تريد حذف مسودة الحادثة هذه. ستتم إزالة هذا الحادث إلى الأبد"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Are you sure you want to delete this incident draft. This incident will be removed permanently"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Está seguro de que desea eliminar este borrador de incidente? Este incidente se eliminará permanentemente."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "क्या आप वाकई इस घटना ड्राफ्ट को हटाना चाहते हैं? इस घटना को स्थायी रूप से हटा दिया जाएगा"
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "کیا آپ واقعی اس واقعے کے مسودے کو حذف کرنا چاہتے ہیں؟ اس واقعہ کو مستقل طور پر ہٹا دیا جائے گا۔"
          }
        }
      }
    },
