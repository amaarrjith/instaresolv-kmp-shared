    "Are you sure you want to leave this page? \n Unsaved changes will be lost." : {
      "comment" : "A subtitle displayed in the \"Leave this page?\" popup, explaining that unsaved changes will be lost if the user leaves the page.",
      "extractionState" : "stale",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هل أنت متأكد أنك تريد مغادرة هذه الصفحة؟ \n سيتم فقدان التغييرات غير المحفوظة."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Are you sure you want to leave this page? \n Unsaved changes will be lost."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Estás seguro de que quieres abandonar esta página? \n Los cambios no guardados se perderán."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "क्या आप वाकई यह पेज छोड़ना चाहते हैं? \n सहेजे न गए परिवर्तन खो जाएंगे."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "کیا آپ واقعی یہ صفحہ چھوڑنا چاہتے ہیں؟ \n غیر محفوظ شدہ تبدیلیاں ضائع ہو جائیں گی۔"
          }
        }
      }
    },
