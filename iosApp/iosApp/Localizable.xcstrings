    "welcome.slide3.description" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تعيين الإجراءات ومراقبة التقدم وإنشاء تقارير السلامة للحفاظ على الامتثال عبر مشاريع ومواقع متعددة."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Assign actions, monitor progress, and generate safety reports to maintain compliance across multiple projects and locations."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Asigne acciones, monitoree el progreso y genere informes de seguridad para mantener el cumplimiento en múltiples proyectos y ubicaciones."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "कार्यों को असाइन करें, प्रगति की निगरानी करें और कई प्रोजेक्ट्स और स्थानों पर अनुपालन बनाए रखने के लिए सुरक्षा रिपोर्ट तैयार करें।"
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "متعدد پروجیکٹس اور مقامات پر تعمیل برقرار رکھنے کے لیے اقدامات تفویض کریں، پیش رفت کی نگرانی کریں، اور حفاظتی رپورٹس تیار کریں۔"
          }
        }
