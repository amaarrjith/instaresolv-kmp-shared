      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هل أنت متأكد أنك تريد حذف مسودة الدرس المستفاد هذه؟ سيتم حذف هذا الدرس نهائيا"
