    "step_by_step_description" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سيتم شرح التفاصيل هنا لطاقم العمل. سيكون المشرف مسؤولاً عن أي عمل يتم إجراؤه ولم يتم تفصيله هنا"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The details here shall be explained to the work crew. The Supervisor will be held responsible for any work that is conducted and not detailed here"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los detalles aquí se explicarán al equipo de trabajo. El Supervisor será responsable de cualquier trabajo que se realice y no se detalle aquí."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "यहां विवरण कार्य दल को समझाया जाएगा। पर्यवेक्षक को ऐसे किसी भी कार्य के लिए जिम्मेदार ठहराया जाएगा जो आयोजित किया गया है और जिसका विवरण यहां नहीं दिया गया है"
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "یہاں کی تفصیلات کام کے عملے کو سمجھائی جائیں گی۔ سپروائزر کسی بھی کام کے لیے ذمہ دار ہوگا جو یہاں کیا گیا ہے اور اس کی تفصیل نہیں ہے۔"
          }
        }
      }
    },
