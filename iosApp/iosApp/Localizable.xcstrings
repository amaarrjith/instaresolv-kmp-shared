    "toolbox_talk_delete" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هل أنت متأكد أنك تريد حذف مسودة نقاش صندوق الأدوات هذه. ستتم إزالة هذا الحادث إلى الأبد"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Are you sure you want to delete this toolbox talk draft. This incident will be removed permanently"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Está seguro de que desea eliminar este borrador de la charla de la caja de herramientas? Este incidente se eliminará permanentemente."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "क्या आप वाकई इस टूलबॉक्स टॉक ड्राफ्ट को हटाना चाहते हैं? इस घटना को स्थायी रूप से हटा दिया जाएगा"
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "کیا آپ واقعی اس ٹول باکس ٹاک ڈرافٹ کو حذف کرنا چاہتے ہیں؟ اس واقعہ کو مستقل طور پر ہٹا دیا جائے گا۔"
          }
        }
      }
    },
