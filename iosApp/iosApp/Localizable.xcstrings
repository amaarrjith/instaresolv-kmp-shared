    "welcome.slide1.description" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "رقمنة عمليات تفتيش السلامة، والإبلاغ عن المخاطر، وإدارة الامتثال من خلال منصة مدعومة بالذكاء الاصطناعي مخصصة لعمليات الموقع الحديثة."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Digitize safety inspections, hazard reporting, and compliance management with an AI-powered platform built for modern site operations."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Digitalice las inspecciones de seguridad, el informe de peligros y la gestión del cumplimiento con una plataforma impulsada por IA diseñada para las operaciones modernas del sitio."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "आधुनिक साइट संचालन के लिए निर्मित एआई-पावर्ड प्लेटफॉर्म के साथ सुरक्षा निरीक्षण, खतरा रिपोर्टिंग और अनुपालन प्रबंधन को डिजिटाइज़ करें।"
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "جدید سائٹ کے آپریشنز کے لیے بنائے گئے AI سے چلنے والے پلیٹ فارم کے ساتھ حفاظتی معائنے، خطرات کی رپورٹنگ، اور تعمیل کے انتظام کو ڈیجیٹل بنائیں۔"
          }
        }
      }
    },
