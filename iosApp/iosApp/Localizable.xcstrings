    "access_restricted_description" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هذا القسم غير متاح حاليًا لحسابات المقاولين الفرعيين. يرجى التواصل مع المسؤول لمزيد من المعلومات."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This section is currently unavailable for subcontractor accounts. Please contact your administrator for more information."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esta sección no está disponible actualmente para cuentas de subcontratistas. Por favor, contacte a su administrador para más información."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "यह अनुभाग वर्तमान में सबकॉन्ट्रैक्टर खातों के लिए उपलब्ध नहीं है। अधिक जानकारी के लिए कृपया अपने व्यवस्थापक से संपर्क करें।"
